{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/additional-items/layout,_N_T_/dashboard/additional-items/page,_N_T_/dashboard/additional-items"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/additional-items/__PAGE__",
    "/dashboard/additional-items",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}